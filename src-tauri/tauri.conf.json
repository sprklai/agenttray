{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentTray",
  "version": "0.1.1",
  "identifier": "com.agenttray.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-*.png"
    ],
    "shortDescription": "System tray monitor for AI coding agents",
    "longDescription": "AgentTray monitors AI coding agents and displays their real-time status via a colored dot in the system tray.",
    "category": "Utility",
    "linux": {
      "deb": {
        "desktopTemplate": "agenttray.desktop"
      },
      "rpm": {
        "desktopTemplate": "agenttray.desktop"
      }
    },
    "macOS": {
      "signingIdentity": "Developer ID Application: NSR Technologies Inc. (6BQSGY2B74)",
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15",
      "providerShortName": "6BQSGY2B74",
      "hardenedRuntime": true
    }
  }
}
