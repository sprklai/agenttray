{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentTray",
  "version": "0.1.0",
  "identifier": "com.agenttray.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "icons/tray-*.png"
    ],
    "shortDescription": "System tray monitor for AI coding agents",
    "longDescription": "AgentTray monitors AI coding agents and displays their real-time status via a colored dot in the system tray.",
    "linux": {
      "deb": {
        "desktopTemplate": null
      }
    }
  }
}
